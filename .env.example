PORT=5000
MONGODB_URI=mongodb://localhost:27017/unicore
JWT_SECRET=your_jwt_secret_key_here_change_in_production
JWT_EXPIRE=7d
NODE_ENV=development

# Paystack
PAYSTACK_SECRET_KEY=your_paystack_secret_key_here
